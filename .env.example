# =============================================================================
# Template de configuration — copier en .env et remplir avec tes vraies valeurs
# =============================================================================
# IMPORTANT : .env est dans .gitignore et ne sera JAMAIS commité.
# Ne jamais commiter ce fichier rempli avec de vraies clés.
# =============================================================================

# --- API Google Gemini (obligatoire) ---
# Crée une clé gratuite sur https://aistudio.google.com
GEMINI_API_KEY=AIza_remplace_par_ta_cle

# Modèle principal (le pipeline cascadera automatiquement vers ~38 modèles
# de fallback en cas de quota épuisé)
GEMINI_MODEL=gemini-2.5-flash

# Taille des batchs envoyés à Gemini (20 = bon compromis tokens / précision)
AI_BATCH_SIZE=20

# --- Gmail SMTP (obligatoire) ---
# GMAIL_PASSWORD doit être un MOT DE PASSE D'APPLICATION 16 caractères
# (pas le password Gmail normal). Génère-en un sur :
# https://myaccount.google.com/apppasswords
GMAIL_USER=ton.email@gmail.com
GMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# --- Destinataires du digest (obligatoire) ---
# Liste séparée par des virgules. Par défaut envoyé à GMAIL_USER si absent.
MAIL_RECIPIENT=ton.email@gmail.com,collegue@entreprise.com

# Score minimum pour qu'un article soit affiché dans le digest (1 à 5)
MAIL_MIN_SCORE=2

# --- Tavily Web Search (optionnel — recherche web élargie) ---
# Clé gratuite (1000 req/mois) sur https://app.tavily.com
# Si absente, le module fait un graceful skip et le pipeline continue.
TAVILY_API_KEY=tvly-remplace_par_ta_cle

# --- Semantic Scholar (optionnel — sinon rate-limit 429 sur l'IP) ---
# Clé gratuite (validation 24-48h) sur https://www.semanticscholar.org/product/api
# Sans cette clé, la source SS est rate-limitée. Avec, 100 req/sec.
SEMANTIC_SCHOLAR_API_KEY=

# =============================================================================
# Proxies résidentiels (optionnels mais FORTEMENT recommandés pour fiabilité
# anti-blocage IP, surtout sur arXiv search, Google News et Google Patents).
# =============================================================================
# Sans proxy : le programme tourne en mode direct (peut subir des bans temporaires).
# Avec proxy : chaque requête sort par une IP résidentielle différente, indistinguable
# d'un vrai utilisateur. Health check au démarrage + failover automatique entre les
# 3 proxies configurés (primaire → backup → tertiaire → mode direct si tous down).
#
# Format : http://USER:PASSWORD@HOST:PORT
#
# Providers recommandés (cout ~5-15$/mois pour ton volume) :
#   - IPRoyal     : https://iproyal.com               (depot min 1$, 7$/GB)
#   - Decodo      : https://decodo.com                (depot min 7$, 8.5$/GB)
#   - Bright Data : https://brightdata.com            (top qualite mais cher)
#
# Setup recommandé : IPRoyal en primaire, Decodo en backup (chez deux providers
# différents pour ne pas dépendre d'un seul).
#
RESIDENTIAL_PROXY_PRIMARY=
RESIDENTIAL_PROXY_BACKUP=
RESIDENTIAL_PROXY_TERTIARY=

# Pays préférentiel pour la geo des IP résidentielles (code ISO 2 lettres).
# La plupart des providers acceptent ce paramètre injecté dans le username.
# Vide = le provider choisit (souvent USA). Recommandé : CH, FR, DE pour ton cas.
# ATTENTION : sur certains trials (Decodo gratuit), le geo-targeting n'est PAS
# inclus et provoque une erreur HTTP 407. Laisser vide en trial gratuit.
PROXY_COUNTRY=CH

# Plafond de bande passante en MB consommee par le proxy (basculement automatique
# en mode direct au-dela). 0 = pas de plafond. Recommande pour trial 100 MB : 80
# Le compteur est cumulatif sur tous les runs (persiste dans data/proxy_bandwidth.json).
# Reset via : python -m src.proxy_manager --reset
PROXY_BANDWIDTH_CAP_MB=0

# =============================================================================
# Compteurs et observabilite
# =============================================================================
# data/proxy_bandwidth.json : cumul des MB consommees via proxy (mis a jour
# automatiquement, lu au demarrage pour appliquer PROXY_BANDWIDTH_CAP_MB).
# Affichage en fin de run dans le log. Reset : `python -m src.proxy_manager --reset`.

# =============================================================================
# Auto-promotion d'acteurs (optionnel)
# =============================================================================
# À la fin de chaque run, les acteurs découverts (Patents/OpenAlex) avec un
# count cumulé >= AUTO_PROMOTE_MIN_COUNT sont ajoutés automatiquement à
# data/targets.json (companies ou research_orgs selon heuristique).
# AUTO_PROMOTE_MAX_PER_RUN limite le nombre de promotions par run pour éviter
# une explosion du nombre de requêtes futures.
AUTO_PROMOTE_MIN_COUNT=30
AUTO_PROMOTE_MAX_PER_RUN=10
